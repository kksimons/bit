{
  "name": "bit",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "check": "bun run lint && bun run lint:rust && bun run typecheck"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tauri-apps/cli": "^2",
    "@types/three": "^0.184.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
